{
  "name": "selection-bridge",
  "displayName": "Selection Bridge",
  "description": "Expose VS Code selection locations to terminal-based coding agents without sending selected text.",
  "version": "0.0.1",
  "publisher": "local",
  "private": false,
  "license": "MIT",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./out/extension.js",
  "files": [
    "bin",
    "out/extension.js",
    "out/pointer.js",
    "out/registry.js",
    "out/server.js",
    "skills",
    "README.md"
  ],
  "bin": {
    "selection-bridge": "./bin/selection-bridge.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "selectionBridge.showCurrentPointer",
        "title": "Selection Bridge: Show Current Pointer"
      },
      {
        "command": "selectionBridge.copyBindCommand",
        "title": "Selection Bridge: Copy Bind Command"
      },
      {
        "command": "selectionBridge.resetInstanceId",
        "title": "Selection Bridge: Reset Instance Id"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/*.test.js",
    "install:local": "bash scripts/install-local.sh",
    "skill:validate": "python3 /Users/aquilaziedins/.codex/skills/.system/skill-creator/scripts/quick_validate.py skills/selection-bridge"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.0"
  }
}
